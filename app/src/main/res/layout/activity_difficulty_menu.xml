<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".DifficultyMenuActivity">

    <!-- ФОНОВОЕ ИЗОБРАЖЕНИЕ: centerCrop предотвращает искажение пропорций -->
    <ImageView
        android:id="@+id/ivBackground"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/landscape_hi05"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/cloud1"
        android:layout_width="200dp"
        android:layout_height="150dp"
        android:layout_marginTop="100dp"
        android:alpha="1"
        android:src="@drawable/cloud_png02"
        app:layout_constraintStart_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/cloud2"
        android:layout_width="200dp"
        android:layout_height="150dp"
        android:layout_marginTop="200dp"
        android:alpha="1"
        android:src="@drawable/cloud_png02"
        app:layout_constraintStart_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/cloud3"
        android:layout_width="250dp"
        android:layout_height="150dp"
        android:layout_marginTop="300dp"
        android:alpha="1"
        android:src="@drawable/cloud_png02"
        app:layout_constraintStart_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 1. Заголовок (LEVEL) -->
    <ImageView
        android:id="@+id/tvTitle"
        android:layout_width="494dp"
        android:layout_height="388dp"
        android:layout_marginTop="-20dp"
        android:layout_marginEnd="-105dp"
        android:scaleType="fitCenter"
        android:src="@drawable/level09"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 2. ОБЩАЯ ПАНЕЛЬ (Картинка с 3 дощечками) -->
    <ImageView
        android:id="@+id/mainPanel"
        android:layout_width="363dp"
        android:layout_height="535dp"
        android:layout_marginTop="-100dp"
        android:scaleType="fitCenter"
        android:src="@drawable/panel_back01"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="4:5"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintVertical_bias="0.0" />

    <!-- 3. Кнопка ЛЕГКИЙ -->

    <!-- 4. Кнопка СРЕДНИЙ -->
    <ImageButton
        android:id="@+id/btnEasy"
        android:layout_width="311dp"
        android:layout_height="92dp"
        android:background="@android:color/transparent"
        android:padding="25dp"
        android:scaleType="fitCenter"
        android:src="@drawable/easy05"
        app:layout_constraintBottom_toBottomOf="@id/mainPanel"
        app:layout_constraintEnd_toEndOf="@id/mainPanel"
        app:layout_constraintHorizontal_bias="0.519"
        app:layout_constraintStart_toStartOf="@id/mainPanel"
        app:layout_constraintTop_toTopOf="@id/mainPanel"
        app:layout_constraintVertical_bias="0.112" />

    <ImageButton
        android:id="@+id/btnMedium"
        android:layout_width="305dp"
        android:layout_height="105dp"
        android:background="@android:color/transparent"
        android:padding="28dp"
        android:scaleType="fitCenter"
        android:src="@drawable/normal03"
        app:layout_constraintBottom_toBottomOf="@id/mainPanel"
        app:layout_constraintEnd_toEndOf="@id/mainPanel"
        app:layout_constraintHorizontal_bias="0.496"
        app:layout_constraintStart_toStartOf="@id/mainPanel"
        app:layout_constraintTop_toTopOf="@id/mainPanel"
        app:layout_constraintVertical_bias="0.44" />

    <!-- 5. Кнопка СЛОЖНЫЙ -->
    <ImageButton
        android:id="@+id/btnHard"
        android:layout_width="321dp"
        android:layout_height="82dp"
        android:background="@android:color/transparent"
        android:padding="20dp"
        android:scaleType="fitCenter"
        android:src="@drawable/hard03"
        app:layout_constraintBottom_toBottomOf="@id/mainPanel"
        app:layout_constraintEnd_toEndOf="@id/mainPanel"
        app:layout_constraintHorizontal_bias="0.642"
        app:layout_constraintStart_toStartOf="@id/mainPanel"
        app:layout_constraintTop_toTopOf="@id/mainPanel"
        app:layout_constraintVertical_bias="0.748" />

    <ImageButton
        android:id="@+id/btnBackToMenu"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:background="@android:color/transparent"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/exit" />
</androidx.constraintlayout.widget.ConstraintLayout>