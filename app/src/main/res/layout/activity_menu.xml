<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MenuActivity">

    <!-- ФОНОВОЕ ИЗОБРАЖЕНИЕ: centerCrop предотвращает растягивание -->
    <ImageView
        android:id="@+id/ivBackground"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/landscape_hi05"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Вставьте это сразу после ivBackground -->
    <ImageView
        android:id="@+id/cloud1"
        android:layout_width="200dp"
        android:layout_height="150dp"
        android:layout_marginTop="100dp"
        android:alpha="1"
        android:src="@drawable/cloud_png02"
        app:layout_constraintStart_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/cloud2"
        android:layout_width="200dp"
        android:layout_height="150dp"
        android:layout_marginTop="200dp"
        android:alpha="1"
        android:src="@drawable/cloud_png02"
        app:layout_constraintStart_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/cloud3"
        android:layout_width="250dp"
        android:layout_height="150dp"
        android:layout_marginTop="300dp"
        android:alpha="1"
        android:src="@drawable/cloud_png02"
        app:layout_constraintStart_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Название игры (Логотип) -->
    <TextView
        android:id="@+id/tvGameTitle"
        android:layout_width="416dp"
        android:layout_height="350dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/tic_tac_toe06"
        android:text=""
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Значок бесконечности -->
    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:translationZ="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/infinite01" />

    <!-- ОБЩАЯ ПАНЕЛЬ ДЛЯ КНОПОК -->
    <ImageView
        android:id="@+id/mainMenuPanel"
        android:layout_width="644dp"
        android:layout_height="468dp"
        android:layout_marginTop="-100dp"
        android:scaleType="fitCenter"
        android:src="@drawable/panel09"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.502"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvGameTitle"
        app:layout_constraintVertical_bias="0.0" />

    <!-- Кнопка: ИГРА С КОМПЬЮТЕРОМ -->

    <!-- Кнопка: ИГРА С ДРУГОМ -->
    <ImageButton
        android:id="@+id/btnVsAi"
        android:layout_width="260dp"
        android:layout_height="180dp"
        android:background="@android:color/transparent"
        android:padding="20dp"
        android:scaleType="fitCenter"
        android:src="@drawable/pvsc05"
        app:layout_constraintBottom_toBottomOf="@id/mainMenuPanel"
        app:layout_constraintEnd_toEndOf="@id/mainMenuPanel"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="@id/mainMenuPanel"
        app:layout_constraintTop_toTopOf="@id/mainMenuPanel"
        app:layout_constraintVertical_bias="0.059" />

    <ImageButton
        android:id="@+id/btnVsFriend"
        android:layout_width="260dp"
        android:layout_height="180dp"
        android:background="@android:color/transparent"
        android:padding="20dp"
        android:scaleType="fitCenter"
        android:src="@drawable/pvsp04"
        app:layout_constraintBottom_toBottomOf="@id/mainMenuPanel"
        app:layout_constraintEnd_toEndOf="@id/mainMenuPanel"
        app:layout_constraintHorizontal_bias="0.494"
        app:layout_constraintStart_toStartOf="@id/mainMenuPanel"
        app:layout_constraintTop_toTopOf="@id/mainMenuPanel"
        app:layout_constraintVertical_bias="0.906" />

    <ImageButton
        android:id="@+id/btnExitApp"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:background="@android:color/transparent"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/exit" />


</androidx.constraintlayout.widget.ConstraintLayout>